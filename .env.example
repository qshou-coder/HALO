# HALO environment variables
# Copy this file to .env and adjust paths to match your setup, or export
# these variables in your shell before invoking any script in scripts/.

# Pretrained model weights (BAGEL, Qwen2.5, SigLIP, ...)
HALO_MODEL_DIR=./downloads/pretrained_models

# Released or downloaded checkpoints (pretrain / finetune / demo)
HALO_CKPT_DIR=./downloads/my_checkpoints

# Training/eval datasets
HALO_DATA_DIR=./download_data

# Where training writes logs, results, checkpoints
HALO_OUTPUT_DIR=./outputs

# Optional: Weights & Biases API key (https://wandb.ai/authorize)
# WANDB_API_KEY=
